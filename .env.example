# FanalytiX — World Cup data provider (server-side only, never sent to the client)
#
# Default provider mapping is football-data.org v4:
#   WORLDCUP_API_BASE_URL=https://api.football-data.org/v4
#   WORLDCUP_API_KEY=<your token from https://www.football-data.org/client/register>
#
# Any provider with a compatible schema works; to use a different vendor,
# implement WorldCupProvider in lib/worldcupApi.ts.

WORLDCUP_API_BASE_URL=
WORLDCUP_API_KEY=

# Optional: competition code (defaults to "WC" — FIFA World Cup)
# WORLDCUP_COMPETITION_CODE=WC
